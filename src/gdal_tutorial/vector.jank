;; on geoms
;; (reproject)
;; (buffer) etc
;; 

(comment
  (GDALAllRegister)

  (vector-info "https://github.com/OSGeo/gdal/raw/refs/heads/master/autotest/ogr/data/parquet/example.parquet")
  (vector-info default-vector-path)

  (let [ds (GDALOpenEx default-vector-path GDAL_OF_VECTOR cpp/nullptr cpp/nullptr cpp/nullptr)
        layer (GDALDatasetGetLayer ds 0)
        _ (OGR_L_ResetReading layer)
        Blayer (cpp/box layer)]
    (take 3 (layer->features Blayer)))

  (let [ds (GDALOpenEx "data/ne_10m_admin_0_countries.gpkg" GDAL_OF_VECTOR cpp/nullptr cpp/nullptr cpp/nullptr)
        _ (when (cpp/== cpp/nullptr ds) (throw "ERROR: failed to open dataset")) ;; todo get gdal errs
        layer (GDALDatasetGetLayer ds 0)
        _ (OGR_L_ResetReading layer)
        Blayer (cpp/box layer)]
    (->> (layer->features Blayer)
         (filter #(= "South America" (get-in % [:properties :CONTINENT]))) ;; filter by property
         count))

  (vector-info default-vector-path)
  (vector-info "https://github.com/OSGeo/gdal/raw/refs/heads/master/autotest/ogr/data/parquet/example.parquet")

  (-main default-vector-path))
